{
	"name": "specpress",
	"version": "3.4.2",
	"description": "Export PDF and/or DOCX files from a subset of Markdown, ASN.1 and JSON files",
	"bin": {
		"sp_export": "./src/bin/export.mjs",
		"sp_generateUML": "./src/bin/generateUML.mjs",
		"sp_generateUML-file": "./src/bin/generateUML-file.mjs",
		"sp_init": "./src/bin/init.mjs",
		"sp_publish": "./src/bin/publish.mjs",
		"sp_start": "./src/bin/start.mjs",
		"sp_serve": "./src/bin/serve.mjs",
		"sp_watch": "./src/bin/watch.mjs",
		"specpress-export-html": "./lib/cli/export-html.js",
		"specpress-export-docx": "./lib/cli/export-docx.js",
		"specpress-validate-ran4": "./lib/cli/validate-38101.js",
		"specpress-normalize-ran4": "./lib/cli/normalize-json-file.js"
	},
	"main": "index.mjs",
	"type": "module",
	"exports": {
		".": {
			"import": "./index.mjs",
			"require": "./lib/index.js"
		},
		"./lib/css/*": "./lib/css/*",
		"./lib/ran4/*": {
			"import": "./dist/lib/ran4/*",
			"require": "./dist/lib/ran4/*"
		}
	},
	"scripts": {
		"test": "node scripts/run-tests.js",
		"test:watch": "node --watch scripts/run-tests.js",
		"build:ran4": "tsc",
		"test:ran4": "node --import tsx --test test/lib/ran4/*.test.ts",
		"prepublishOnly": "tsc",
		"release": "node scripts/release.cjs"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/Ericsson/specpress"
	},
	"keywords": [
		"3GPP",
		"ASN.1",
		"DOCX",
		"JSON",
		"Markdown",
		"PDF"
	],
	"author": "Serban Purge <serban.purge@ericsson.com>",
	"license": "MIT",
	"dependencies": {
		"ajv": "^8.20.0",
		"ajv-formats": "^3.0.1",
		"docx": "^9.6.1",
		"htmldiff-js": "^1.0.5",
		"katex": "^0.16.38",
		"markdown-it": "^14.1.1",
		"markdown-it-emoji": "^2.0.2",
		"markdown-it-task-lists": "^2.1.1",
		"markdown-it-texmath": "^1.0.0",
		"mathml2omml": "^0.5.0"
	},
	"optionalDependencies": {
		"chokidar": "^4.0.3",
		"http-server": "^14.1.1",
		"node-plantuml": "^0.9.0"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"tsx": "^4.19.0",
		"typescript": "^5.6.0"
	}
}
